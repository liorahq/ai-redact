{
  "name": "ai-redact",
  "version": "0.1.0",
  "private": true,
  "description": "Personal data interceptor for AI. Catches PII and secrets before they reach AI models.",
  "workspaces": [
    "packages/*",
    "extensions/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "license": "Apache-2.0"
}
