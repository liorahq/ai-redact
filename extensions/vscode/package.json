{
  "name": "ai-redact",
  "displayName": "AI Redact — PII & Secret Scanner for AI Assistants",
  "description": "Catches PII, secrets, and credentials before they reach AI models. Scans code in real-time and intercepts AI chat prompts.",
  "version": "0.1.0",
  "publisher": "liorahq",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/liorahq/ai-redact"
  },
  "homepage": "https://github.com/liorahq/ai-redact#readme",
  "bugs": {
    "url": "https://github.com/liorahq/ai-redact/issues"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "AI security",
    "DLP",
    "PII detection",
    "secrets scanner",
    "data loss prevention",
    "credential scanner",
    "privacy",
    "GDPR",
    "EU AI Act",
    "Copilot security",
    "ChatGPT security",
    "sensitive data",
    "API key scanner",
    "secret detection",
    "data protection"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "ai-redact.redact",
        "name": "redact",
        "fullName": "AI Redact",
        "description": "Scans your prompt for PII and secrets before sending to AI. Use @redact to protect your data.",
        "isSticky": false,
        "commands": [
          {
            "name": "scan",
            "description": "Scan a prompt for sensitive data without sending it to AI"
          }
        ]
      }
    ],
    "configuration": {
      "title": "AI Redact",
      "properties": {
        "aiRedact.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable AI Redact scanning"
        },
        "aiRedact.scanOnType": {
          "type": "boolean",
          "default": true,
          "description": "Scan documents as you type"
        },
        "aiRedact.minSeverity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "default": "medium",
          "description": "Minimum severity level to report"
        },
        "aiRedact.enabledDetectors": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of detector names to enable. Empty means all detectors are active."
        },
        "aiRedact.secretSeverity": {
          "type": "string",
          "enum": ["warning", "error"],
          "default": "error",
          "description": "Diagnostic severity for secrets (error = red, warning = yellow)"
        },
        "aiRedact.piiSeverity": {
          "type": "string",
          "enum": ["warning", "error", "information"],
          "default": "warning",
          "description": "Diagnostic severity for PII detections"
        },
        "aiRedact.interceptionMode": {
          "type": "string",
          "enum": ["warn", "redact", "block"],
          "default": "warn",
          "enumDescriptions": [
            "Show a warning but forward the original prompt to the AI model",
            "Automatically redact sensitive data before forwarding to the AI model",
            "Block the request entirely if sensitive data is detected"
          ],
          "description": "How the proxy model handles detected sensitive data in AI chat prompts"
        }
      }
    },
    "commands": [
      {
        "command": "aiRedact.scanCurrentFile",
        "title": "AI Redact: Scan Current File"
      },
      {
        "command": "aiRedact.redactAll",
        "title": "AI Redact: Redact All Findings in Current File"
      },
      {
        "command": "aiRedact.toggleEnabled",
        "title": "AI Redact: Toggle Scanner"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@ai-redact/core": "*"
  }
}
